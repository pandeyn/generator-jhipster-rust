apiVersion: v1
kind: Secret
metadata:
  name: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}-secret
  namespace: {{ .Release.Namespace }}
  labels:
    {{- include "<%= baseName.toLowerCase() %>.labels" . | nindent 4 }}
type: Opaque
stringData:
  {{- range $key, $value := .Values.secrets }}
  {{ $key }}: {{ $value | quote }}
  {{- end }}

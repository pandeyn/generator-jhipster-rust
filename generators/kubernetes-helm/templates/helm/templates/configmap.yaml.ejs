apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}-config
  namespace: {{ .Release.Namespace }}
  labels:
    {{- include "<%= baseName.toLowerCase() %>.labels" . | nindent 4 }}
data:
  {{- range $key, $value := .Values.config }}
  {{ $key }}: {{ $value | quote }}
  {{- end }}

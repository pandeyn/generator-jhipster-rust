#!/usr/bin/env bash
# Generated by JHipster Rust - Helm deployment script
# Usage: ./helm/helm-apply.sh [install|upgrade|uninstall|template]

set -euo pipefail

ACTION="${1:-install}"
RELEASE_NAME="<%= baseName.toLowerCase() %>"
CHART_DIR="helm/<%= baseName.toLowerCase() %>"
NAMESPACE="<%= kubernetesNamespace %>"

echo "Helm ${ACTION} for ${RELEASE_NAME} (namespace: ${NAMESPACE})"
echo "============================================="

if [ "${ACTION}" = "install" ]; then

  # Pre-flight check: verify the application Docker image exists
  APP_IMAGE="<%= dockerImageName %>:latest"
  if ! docker image inspect "${APP_IMAGE}" > /dev/null 2>&1; then
    echo ""
    echo "ERROR: Docker image '${APP_IMAGE}' not found locally."
    echo "Build it first with:"
    echo "  docker build -t ${APP_IMAGE} ."
    echo ""
    exit 1
  fi

  # Load images into local cluster if applicable
  CLUSTER_NODE=$(kubectl get nodes -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
  if [ -n "${CLUSTER_NODE}" ] && docker exec "${CLUSTER_NODE}" true 2>/dev/null; then
    load_image() {
      local img="$1"
      if ! docker image inspect "${img}" > /dev/null 2>&1; then
        echo "  Pulling ${img}..."
        docker pull "${img}" > /dev/null 2>&1 || { echo "  WARNING: Failed to pull ${img}"; return; }
      fi
      echo "  Loading ${img}..."
      docker save "${img}" | docker exec -i "${CLUSTER_NODE}" ctr -n k8s.io images import - > /dev/null 2>&1 \
        || echo "  WARNING: Failed to load ${img} into cluster node."
    }

    echo "Loading Docker images into cluster node '${CLUSTER_NODE}'..."
    load_image "${APP_IMAGE}"
<%_ if (devDatabaseTypePostgresql) { _%>
    load_image "postgres:16-alpine"
<%_ } else if (devDatabaseTypeMysql) { _%>
    load_image "mysql:8.0"
<%_ } else if (devDatabaseTypeMongodb) { _%>
    load_image "mongo:7.0"
<%_ } _%>
<%_ if (serviceDiscoveryConsul) { _%>
    load_image "hashicorp/consul:1.15"
<%_ } _%>
<%_ if (messageBrokerKafka) { _%>
    load_image "confluentinc/cp-zookeeper:7.5.0"
    load_image "confluentinc/cp-kafka:7.5.0"
<%_ } _%>
<%_ if (authenticationTypeOauth2) { _%>
    load_image "quay.io/keycloak/keycloak:23.0"
<%_ } _%>
<%_ if (monitoringPrometheus) { _%>
    load_image "prom/prometheus:v2.48.0"
    load_image "grafana/grafana:10.2.0"
<%_ } _%>
    echo "All images loaded."
  fi

  echo "Installing Helm chart..."
<%_ if (kubernetesNamespace !== 'default') { _%>
  helm install "${RELEASE_NAME}" "${CHART_DIR}" --namespace "${NAMESPACE}" --create-namespace
<%_ } else { _%>
  helm install "${RELEASE_NAME}" "${CHART_DIR}" --namespace "${NAMESPACE}"
<%_ } _%>

  echo ""
  echo "Deployment complete!"

elif [ "${ACTION}" = "upgrade" ]; then
  echo "Upgrading Helm release..."
  helm upgrade "${RELEASE_NAME}" "${CHART_DIR}" --namespace "${NAMESPACE}"
  echo "Upgrade complete!"

elif [ "${ACTION}" = "uninstall" ]; then
  echo "Uninstalling Helm release..."
  helm uninstall "${RELEASE_NAME}" --namespace "${NAMESPACE}"
  echo "Cleaning up PVCs..."
  kubectl delete pvc -l app.kubernetes.io/instance=${RELEASE_NAME} -n ${NAMESPACE} --ignore-not-found
<%_ if (devDatabaseTypePostgresql) { _%>
  kubectl delete pvc -l app=${RELEASE_NAME}-postgresql -n ${NAMESPACE} --ignore-not-found
  kubectl delete pvc postgresql-data-${RELEASE_NAME}-postgresql-0 -n ${NAMESPACE} --ignore-not-found
<%_ } else if (devDatabaseTypeMysql) { _%>
  kubectl delete pvc -l app=${RELEASE_NAME}-mysql -n ${NAMESPACE} --ignore-not-found
  kubectl delete pvc mysql-data-${RELEASE_NAME}-mysql-0 -n ${NAMESPACE} --ignore-not-found
<%_ } else if (devDatabaseTypeMongodb) { _%>
  kubectl delete pvc -l app=${RELEASE_NAME}-mongodb -n ${NAMESPACE} --ignore-not-found
  kubectl delete pvc mongodb-data-${RELEASE_NAME}-mongodb-0 -n ${NAMESPACE} --ignore-not-found
<%_ } _%>
<%_ if (serviceDiscoveryConsul) { _%>
  kubectl delete pvc consul-data-${RELEASE_NAME}-consul-0 -n ${NAMESPACE} --ignore-not-found
<%_ } _%>
<%_ if (messageBrokerKafka) { _%>
  kubectl delete pvc zookeeper-data-${RELEASE_NAME}-zookeeper-0 -n ${NAMESPACE} --ignore-not-found
  kubectl delete pvc kafka-data-${RELEASE_NAME}-kafka-0 -n ${NAMESPACE} --ignore-not-found
<%_ } _%>
  echo "Uninstall complete."

elif [ "${ACTION}" = "template" ]; then
  echo "Rendering templates (dry-run)..."
  helm template "${RELEASE_NAME}" "${CHART_DIR}" --namespace "${NAMESPACE}"

else
  echo "Usage: $0 [install|upgrade|uninstall|template]"
  exit 1
fi

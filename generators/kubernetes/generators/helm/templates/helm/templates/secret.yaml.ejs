apiVersion: v1
kind: Secret
metadata:
  name: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}-secret
  namespace: {{ .Release.Namespace }}
  labels:
    {{- include "<%= baseName.toLowerCase() %>.labels" . | nindent 4 }}
type: Opaque
stringData:
  # JWT_SECRET uses a lookup-or-generate pattern so the value is created on
  # first install AND preserved across `helm upgrade` runs (otherwise every
  # upgrade would rotate the signing key and invalidate all in-flight tokens).
  # Resolution order:
  #   1. existing in-cluster Secret (preserves rolling-deploy continuity)
  #   2. .Values.secrets.JWT_SECRET (operator override via --set)
  #   3. randAlphaNum 32 (one-time generation on first install)
  #
  # NOTE: stringData auto-base64-encodes — do NOT add b64enc here; that would
  # double-encode and corrupt the secret.
  {{- $secretName := printf "%s-secret" (include "<%= baseName.toLowerCase() %>.fullname" .) }}
  {{- $existing := lookup "v1" "Secret" .Release.Namespace $secretName }}
  {{- if and $existing (index $existing.data "JWT_SECRET") }}
  JWT_SECRET: {{ index $existing.data "JWT_SECRET" | b64dec | quote }}
  {{- else if .Values.secrets.JWT_SECRET }}
  JWT_SECRET: {{ .Values.secrets.JWT_SECRET | quote }}
  {{- else }}
  JWT_SECRET: {{ randAlphaNum 32 | quote }}
  {{- end }}
  {{- range $key, $value := .Values.secrets }}
  {{- if and (ne $key "JWT_SECRET") $value }}
  {{ $key }}: {{ $value | quote }}
  {{- end }}
  {{- end }}

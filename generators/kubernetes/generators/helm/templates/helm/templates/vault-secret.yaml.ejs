{{- if .Values.vault.enabled }}
apiVersion: v1
kind: Secret
metadata:
  name: {{ .Release.Name }}-vault-secret
  namespace: {{ .Release.Namespace }}
  labels:
    app: {{ .Release.Name }}-vault
    {{- include "<%= baseName.toLowerCase() %>.labels" . | nindent 4 }}
type: Opaque
stringData:
  VAULT_ADDR: "http://{{ .Release.Name }}-vault:8200"
  VAULT_AUTH_METHOD: "token"
  VAULT_TOKEN: "myroot"
  VAULT_SECRET_PATH: "secret/data/{{ .Release.Name | lower }}"
{{- end }}

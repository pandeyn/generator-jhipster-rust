apiVersion: v1
kind: Service
metadata:
  name: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}
  namespace: {{ .Release.Namespace }}
  labels:
    {{- include "<%= baseName.toLowerCase() %>.labels" . | nindent 4 }}
spec:
  type: {{ .Values.service.type }}
  selector:
    {{- include "<%= baseName.toLowerCase() %>.selectorLabels" . | nindent 4 }}
  ports:
    - name: http
      port: {{ .Values.service.port }}
      targetPort: http
      protocol: TCP

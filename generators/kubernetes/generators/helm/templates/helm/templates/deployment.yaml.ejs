apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}
  namespace: {{ .Release.Namespace }}
  labels:
    {{- include "<%= baseName.toLowerCase() %>.labels" . | nindent 4 }}
spec:
  {{- if not .Values.autoscaling.enabled }}
  replicas: {{ .Values.replicaCount }}
  {{- end }}
  selector:
    matchLabels:
      {{- include "<%= baseName.toLowerCase() %>.selectorLabels" . | nindent 6 }}
  template:
    metadata:
      labels:
        {{- include "<%= baseName.toLowerCase() %>.selectorLabels" . | nindent 8 }}
      annotations:
        checksum/config: {{ include (print $.Template.BasePath "/configmap.yaml") . | sha256sum }}
        checksum/secret: {{ include (print $.Template.BasePath "/secret.yaml") . | sha256sum }}
<%_ if (monitoringPrometheus) { _%>
        prometheus.io/scrape: "true"
        prometheus.io/port: "{{ .Values.service.port }}"
        prometheus.io/path: "/api/metrics"
<%_ } _%>
    spec:
      containers:
        - name: {{ .Chart.Name }}
          image: "{{ .Values.image.repository }}:{{ .Values.image.tag }}"
          imagePullPolicy: {{ .Values.image.pullPolicy }}
          ports:
            - name: http
              containerPort: {{ .Values.service.port }}
              protocol: TCP
          envFrom:
            - configMapRef:
                name: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}-config
            - secretRef:
                name: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}-secret
<%_ if (secretsManagementVault) { _%>
            {{- if .Values.vault.enabled }}
            - secretRef:
                name: {{ .Release.Name }}-vault-secret
            {{- end }}
<%_ } _%>
<%_ if (devDatabaseTypePostgresql || devDatabaseTypeMysql) { _%>
          # DATABASE_URL is assembled here (not in the ConfigMap) so the
          # password lives only in the Secret. K8s expands $(DB_PASSWORD)
          # from the envFrom-imported Secret key — supported since K8s 1.7.
          env:
<%_ if (devDatabaseTypePostgresql) { _%>
            - name: DATABASE_URL
              value: "postgres://postgres:$(DB_PASSWORD)@<%= baseName.toLowerCase() %>-postgresql:5432/<%= baseName.toLowerCase() %>"
<%_ } else if (devDatabaseTypeMysql) { _%>
            - name: DATABASE_URL
              value: "mysql://root:$(DB_PASSWORD)@<%= baseName.toLowerCase() %>-mysql:3306/<%= baseName.toLowerCase() %>"
<%_ } _%>
<%_ } _%>
          livenessProbe:
            httpGet:
              path: /api/health/liveness
              port: http
            initialDelaySeconds: 20
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /api/health/readiness
              port: http
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          resources:
            {{- toYaml .Values.resources | nindent 12 }}
<%_ if (devDatabaseTypeSqlite) { _%>
          volumeMounts:
            - name: sqlite-data
              mountPath: /app/data
      volumes:
        - name: sqlite-data
          persistentVolumeClaim:
            claimName: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}-sqlite-pvc
<%_ } _%>
<%_ if (devDatabaseTypeSqlite) { _%>
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ include "<%= baseName.toLowerCase() %>.fullname" . }}-sqlite-pvc
  namespace: {{ .Release.Namespace }}
  labels:
    {{- include "<%= baseName.toLowerCase() %>.labels" . | nindent 4 }}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
<%_ } _%>

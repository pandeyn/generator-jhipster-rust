apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: <%= baseName.toLowerCase() %>-vault
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-vault
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-vault
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  serviceName: <%= baseName.toLowerCase() %>-vault
  replicas: 1
  selector:
    matchLabels:
      app: <%= baseName.toLowerCase() %>-vault
  template:
    metadata:
      labels:
        app: <%= baseName.toLowerCase() %>-vault
        app.kubernetes.io/name: <%= baseName.toLowerCase() %>-vault
        app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    spec:
      containers:
        - name: vault
          image: hashicorp/vault:1.15
          imagePullPolicy: IfNotPresent
          args:
            - server
            - -dev
            - -dev-root-token-id=myroot
            - -dev-listen-address=0.0.0.0:8200
          env:
            - name: VAULT_ADDR
              value: "http://127.0.0.1:8200"
            - name: VAULT_API_ADDR
              value: "http://<%= baseName.toLowerCase() %>-vault:8200"
          ports:
            - name: http
              containerPort: 8200
              protocol: TCP
          securityContext:
            capabilities:
              add:
                - IPC_LOCK
          livenessProbe:
            exec:
              command:
                - vault
                - status
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            exec:
              command:
                - vault
                - status
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "250m"
          volumeMounts:
            - name: vault-data
              mountPath: /vault/data
  volumeClaimTemplates:
    - metadata:
        name: vault-data
      spec:
        accessModes:
          - ReadWriteOnce
        resources:
          requests:
            storage: 1Gi
---
apiVersion: v1
kind: Service
metadata:
  name: <%= baseName.toLowerCase() %>-vault
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-vault
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-vault
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  type: ClusterIP
  selector:
    app: <%= baseName.toLowerCase() %>-vault
  ports:
    - name: http
      port: 8200
      targetPort: http
      protocol: TCP

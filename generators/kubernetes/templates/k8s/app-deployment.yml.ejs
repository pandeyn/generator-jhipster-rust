apiVersion: apps/v1
kind: Deployment
metadata:
  name: <%= baseName.toLowerCase() %>
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  replicas: <%= kubernetesReplicas %>
  selector:
    matchLabels:
      app: <%= baseName.toLowerCase() %>
  template:
    metadata:
      labels:
        app: <%= baseName.toLowerCase() %>
        app.kubernetes.io/name: <%= baseName.toLowerCase() %>
        app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
<%_ if (monitoringPrometheus) { _%>
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "<%= appPort %>"
        prometheus.io/path: "/api/metrics"
<%_ } _%>
    spec:
      containers:
        - name: <%= baseName.toLowerCase() %>
          image: <%= dockerImageName %>:latest
          imagePullPolicy: IfNotPresent
          # Defense-in-depth: enforce non-root + drop all caps + read-only rootfs
          # where possible. UID 1001 must match the Dockerfile's USER directive.
          securityContext:
            runAsNonRoot: true
            runAsUser: 1001
            allowPrivilegeEscalation: false
<%_ if (devDatabaseTypeSqlite) { _%>
            readOnlyRootFilesystem: false  # SQLite default writes to /app/target/db
<%_ } else { _%>
            readOnlyRootFilesystem: true
<%_ } _%>
            capabilities:
              drop: [ALL]
          ports:
            - name: http
              containerPort: <%= appPort %>
              protocol: TCP
          envFrom:
            - configMapRef:
                name: <%= baseName.toLowerCase() %>-config
            - secretRef:
                name: <%= baseName.toLowerCase() %>-secret
<%_ if (secretsManagementVault) { _%>
            - secretRef:
                name: <%= baseName.toLowerCase() %>-vault-secret
<%_ } _%>
<%_ if (devDatabaseTypePostgresql || devDatabaseTypeMysql) { _%>
          # DATABASE_URL is assembled here (not in the ConfigMap) so the
          # password lives only in app-secret. K8s expands the $(VAR) syntax
          # against envFrom-imported Secret keys — supported since K8s 1.7.
          # The operator must populate POSTGRES_PASSWORD or MYSQL_ROOT_PASSWORD
          # in app-secret before applying this manifest (see app-secret.yml).
          env:
<%_ if (devDatabaseTypePostgresql) { _%>
            - name: DATABASE_URL
              value: "postgres://postgres:$(POSTGRES_PASSWORD)@<%= baseName.toLowerCase() %>-postgresql:5432/<%= baseName.toLowerCase() %>"
<%_ } else if (devDatabaseTypeMysql) { _%>
            - name: DATABASE_URL
              value: "mysql://root:$(MYSQL_ROOT_PASSWORD)@<%= baseName.toLowerCase() %>-mysql:3306/<%= baseName.toLowerCase() %>"
<%_ } _%>
<%_ } _%>
          livenessProbe:
            httpGet:
              path: /api/health/liveness
              port: http
            initialDelaySeconds: 20
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /api/health/readiness
              port: http
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "500m"
<%_ if (devDatabaseTypeSqlite) { _%>
          volumeMounts:
            - name: sqlite-data
              mountPath: /app/data
      volumes:
        - name: sqlite-data
          persistentVolumeClaim:
            claimName: <%= baseName.toLowerCase() %>-sqlite-pvc
<%_ } else { _%>
          # /tmp is required writable by tokio/rustls/panic-dump even when the
          # rest of the rootfs is read-only. emptyDir is per-pod and ephemeral.
          volumeMounts:
            - name: tmp
              mountPath: /tmp
      volumes:
        - name: tmp
          emptyDir: {}
<%_ } _%>
---
<%_ if (devDatabaseTypeSqlite) { _%>
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: <%= baseName.toLowerCase() %>-sqlite-pvc
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
<%_ } _%>

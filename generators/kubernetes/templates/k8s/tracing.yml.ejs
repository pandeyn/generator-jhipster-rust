<%_ if (distributedTracingZipkin) { _%>
apiVersion: apps/v1
kind: Deployment
metadata:
  name: <%= baseName.toLowerCase() %>-zipkin
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-zipkin
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-zipkin
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  replicas: 1
  selector:
    matchLabels:
      app: <%= baseName.toLowerCase() %>-zipkin
  template:
    metadata:
      labels:
        app: <%= baseName.toLowerCase() %>-zipkin
        app.kubernetes.io/name: <%= baseName.toLowerCase() %>-zipkin
        app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    spec:
      containers:
        - name: zipkin
          image: openzipkin/zipkin:3
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 9411
              protocol: TCP
          env:
            - name: STORAGE_TYPE
              value: "mem"
          livenessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 15
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          resources:
            requests:
              memory: "256Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "250m"
---
apiVersion: v1
kind: Service
metadata:
  name: <%= baseName.toLowerCase() %>-zipkin
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-zipkin
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-zipkin
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  type: ClusterIP
  selector:
    app: <%= baseName.toLowerCase() %>-zipkin
  ports:
    - name: http
      port: 9411
      targetPort: http
      protocol: TCP
<%_ } else if (distributedTracingJaeger) { _%>
apiVersion: apps/v1
kind: Deployment
metadata:
  name: <%= baseName.toLowerCase() %>-jaeger
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-jaeger
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-jaeger
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  replicas: 1
  selector:
    matchLabels:
      app: <%= baseName.toLowerCase() %>-jaeger
  template:
    metadata:
      labels:
        app: <%= baseName.toLowerCase() %>-jaeger
        app.kubernetes.io/name: <%= baseName.toLowerCase() %>-jaeger
        app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    spec:
      containers:
        - name: jaeger
          image: jaegertracing/all-in-one:latest
          imagePullPolicy: IfNotPresent
          ports:
            - name: ui
              containerPort: 16686
              protocol: TCP
            - name: otlp-grpc
              containerPort: 4317
              protocol: TCP
            - name: otlp-http
              containerPort: 4318
              protocol: TCP
          env:
            - name: COLLECTOR_OTLP_ENABLED
              value: "true"
          livenessProbe:
            httpGet:
              path: /
              port: ui
            initialDelaySeconds: 15
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /
              port: ui
            initialDelaySeconds: 5
            periodSeconds: 10
          resources:
            requests:
              memory: "256Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "250m"
---
apiVersion: v1
kind: Service
metadata:
  name: <%= baseName.toLowerCase() %>-jaeger
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-jaeger
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-jaeger
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  type: ClusterIP
  selector:
    app: <%= baseName.toLowerCase() %>-jaeger
  ports:
    - name: ui
      port: 16686
      targetPort: ui
      protocol: TCP
    - name: otlp-grpc
      port: 4317
      targetPort: otlp-grpc
      protocol: TCP
    - name: otlp-http
      port: 4318
      targetPort: otlp-http
      protocol: TCP
<%_ } _%>

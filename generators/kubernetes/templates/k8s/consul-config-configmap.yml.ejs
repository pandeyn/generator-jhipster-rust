apiVersion: v1
kind: ConfigMap
metadata:
  name: <%= baseName.toLowerCase() %>-consul-config
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-consul-config
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-consul-config
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
data:
  application.yml: |
    # Central configuration for all microservices
    # Loaded into Consul KV store by consul-config-loader

    configserver:
      name: Kubernetes Consul Config Server
      status: Connected to Consul Server running in Kubernetes

<%_ if (authenticationTypeJwt) { _%>
    jwt:
      # IMPORTANT: Change this secret in production!
      # This secret should be shared across all microservices for JWT validation
      secret: change-me-in-production
      expiration_hours: 24
<%_ } _%>

    # Common database settings (override per-service as needed)
    database:
      pool_size: 10
      timeout_seconds: 30

    # Logging configuration
    logging:
      level: info
      format: json

    # Health check configuration
    health:
      interval_seconds: 10
      timeout_seconds: 5
  application-dev.yml: |
    # Development profile configuration
    logging:
      level: debug
      format: text
    database:
      pool_size: 5
      timeout_seconds: 30
    health:
      interval_seconds: 15
      timeout_seconds: 10
  application-prod.yml: |
    # Production profile configuration
    logging:
      level: info
      format: json
    database:
      pool_size: 20
      timeout_seconds: 15
    health:
      interval_seconds: 10
      timeout_seconds: 5

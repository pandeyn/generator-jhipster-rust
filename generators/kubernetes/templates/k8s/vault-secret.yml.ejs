apiVersion: v1
kind: Secret
metadata:
  name: <%= baseName.toLowerCase() %>-vault-secret
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-vault
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-vault-secret
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
type: Opaque
# IMPORTANT: In production, these should be populated by the vault-init job
# or a Vault injector sidecar. These are dev defaults.
stringData:
  VAULT_ADDR: "http://<%= baseName.toLowerCase() %>-vault:8200"
  VAULT_AUTH_METHOD: "token"
  VAULT_TOKEN: "myroot"
  VAULT_SECRET_PATH: "secret/data/<%= baseName.toLowerCase() %>"

apiVersion: v1
kind: Secret
metadata:
  name: <%= baseName.toLowerCase() %>-secret
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
type: Opaque
# IMPORTANT: This manifest INTENTIONALLY ships with no secret values.
# Applying it as-is creates an empty Secret; the application will refuse to
# start until the operator supplies the required values. Pick ONE approach:
#
# === Approach 1: edit-and-apply ============================================
# Replace `stringData: {}` below with the block-form mapping, e.g.:
#
#   stringData:
<%_ if (authenticationTypeJwt && !secretsManagementVault) { _%>
#     JWT_SECRET: "<paste output of: openssl rand -hex 32>"
<%_ } _%>
<%_ if (devDatabaseTypePostgresql) { _%>
#     POSTGRES_PASSWORD: "<paste output of: openssl rand -base64 24>"
<%_ } else if (devDatabaseTypeMysql) { _%>
#     MYSQL_ROOT_PASSWORD: "<paste output of: openssl rand -base64 24>"
<%_ } _%>
#
# Values are plaintext — Kubernetes auto-base64-encodes stringData fields.
#
# === Approach 2: kubectl (no edits to this file) ===========================
# Skip applying this manifest and create the Secret directly:
#   kubectl create secret generic <%= baseName.toLowerCase() %>-secret \
#     -n <%= kubernetesNamespace %> \
<%_ if (authenticationTypeJwt && !secretsManagementVault) { _%>
#     --from-literal=JWT_SECRET="$(openssl rand -hex 32)" \
<%_ } _%>
<%_ if (devDatabaseTypePostgresql) { _%>
#     --from-literal=POSTGRES_PASSWORD="$(openssl rand -base64 24)"
<%_ } else if (devDatabaseTypeMysql) { _%>
#     --from-literal=MYSQL_ROOT_PASSWORD="$(openssl rand -base64 24)"
<%_ } _%>
#
# === Approach 3: Helm chart ================================================
# The Helm chart auto-generates JWT_SECRET on first install and preserves it
# across upgrades (lookup-or-generate pattern). See README-helm.md.
stringData: {}
<%_ if (authenticationTypeJwt && secretsManagementVault) { _%>
# (JWT_SECRET is managed by Vault — see vault-secret.yml)
<%_ } _%>

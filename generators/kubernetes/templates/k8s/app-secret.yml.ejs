apiVersion: v1
kind: Secret
metadata:
  name: <%= baseName.toLowerCase() %>-secret
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
type: Opaque
# IMPORTANT: Change these values in production!
# Use: echo -n 'value' | base64
stringData:
<%_ if (authenticationTypeJwt && !secretsManagementVault) { _%>
  JWT_SECRET: "your-super-secret-jwt-key-change-in-production"
<%_ } _%>
<%_ if (authenticationTypeJwt && secretsManagementVault) { _%>
  # JWT_SECRET is managed by Vault - see vault-secret.yml
<%_ } _%>
<%_ if (devDatabaseTypePostgresql) { _%>
  POSTGRES_PASSWORD: "postgres"
<%_ } else if (devDatabaseTypeMysql) { _%>
  MYSQL_ROOT_PASSWORD: "root"
<%_ } _%>

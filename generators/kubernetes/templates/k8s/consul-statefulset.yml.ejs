apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: <%= baseName.toLowerCase() %>-consul
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-consul
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-consul
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  serviceName: <%= baseName.toLowerCase() %>-consul
  replicas: 1
  selector:
    matchLabels:
      app: <%= baseName.toLowerCase() %>-consul
  template:
    metadata:
      labels:
        app: <%= baseName.toLowerCase() %>-consul
        app.kubernetes.io/name: <%= baseName.toLowerCase() %>-consul
        app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    spec:
      containers:
        - name: consul
          image: hashicorp/consul:1.15
          args:
            - agent
            - -server
            - -bootstrap-expect=1
            - -ui
            - -client=0.0.0.0
            - -data-dir=/consul/data
            - -log-level=INFO
          ports:
            - name: http
              containerPort: 8500
              protocol: TCP
            - name: dns-tcp
              containerPort: 8600
              protocol: TCP
            - name: dns-udp
              containerPort: 8600
              protocol: UDP
            - name: serf-lan
              containerPort: 8301
              protocol: TCP
            - name: serf-wan
              containerPort: 8302
              protocol: TCP
            - name: server
              containerPort: 8300
              protocol: TCP
          livenessProbe:
            exec:
              command:
                - consul
                - members
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            exec:
              command:
                - consul
                - members
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "250m"
          volumeMounts:
            - name: consul-data
              mountPath: /consul/data
  volumeClaimTemplates:
    - metadata:
        name: consul-data
      spec:
        accessModes:
          - ReadWriteOnce
        resources:
          requests:
            storage: 1Gi
---
apiVersion: v1
kind: Service
metadata:
  name: <%= baseName.toLowerCase() %>-consul
  namespace: <%= kubernetesNamespace %>
  labels:
    app: <%= baseName.toLowerCase() %>-consul
    app.kubernetes.io/name: <%= baseName.toLowerCase() %>-consul
    app.kubernetes.io/part-of: <%= baseName.toLowerCase() %>
    app.kubernetes.io/managed-by: jhipster-rust
spec:
  type: ClusterIP
  selector:
    app: <%= baseName.toLowerCase() %>-consul
  ports:
    - name: http
      port: 8500
      targetPort: http
      protocol: TCP
    - name: dns-tcp
      port: 8600
      targetPort: dns-tcp
      protocol: TCP
    - name: dns-udp
      port: 8600
      targetPort: dns-udp
      protocol: UDP

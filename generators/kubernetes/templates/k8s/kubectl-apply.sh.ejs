#!/usr/bin/env bash
# Generated by JHipster Rust - Kubernetes deployment script
# Usage: ./k8s/kubectl-apply.sh [apply|delete]

set -euo pipefail

ACTION="${1:-apply}"
NAMESPACE="<%= kubernetesNamespace %>"

echo "Kubernetes ${ACTION} for <%= baseName.toLowerCase() %> (namespace: ${NAMESPACE})"
echo "============================================="

if [ "${ACTION}" = "apply" ]; then
<%_ if (kubernetesNamespace !== 'default') { _%>
  echo "Creating namespace..."
  kubectl apply -f k8s/namespace.yml
<%_ } _%>

  echo "Applying secrets and config..."
  kubectl apply -f k8s/app-secret.yml
  kubectl apply -f k8s/app-configmap.yml

<%_ if (devDatabaseTypePostgresql) { _%>
  echo "Deploying PostgreSQL..."
  kubectl apply -f k8s/postgresql-statefulset.yml
  echo "Waiting for PostgreSQL to be ready..."
  kubectl rollout status statefulset/<%= baseName.toLowerCase() %>-postgresql -n ${NAMESPACE} --timeout=120s
<%_ } else if (devDatabaseTypeMysql) { _%>
  echo "Deploying MySQL..."
  kubectl apply -f k8s/mysql-statefulset.yml
  echo "Waiting for MySQL to be ready..."
  kubectl rollout status statefulset/<%= baseName.toLowerCase() %>-mysql -n ${NAMESPACE} --timeout=120s
<%_ } else if (devDatabaseTypeMongodb) { _%>
  echo "Deploying MongoDB..."
  kubectl apply -f k8s/mongodb-statefulset.yml
  echo "Waiting for MongoDB to be ready..."
  kubectl rollout status statefulset/<%= baseName.toLowerCase() %>-mongodb -n ${NAMESPACE} --timeout=120s
<%_ } _%>

<%_ if (serviceDiscoveryConsul) { _%>
  echo "Deploying Consul..."
  kubectl apply -f k8s/consul-statefulset.yml
  echo "Waiting for Consul to be ready..."
  kubectl rollout status statefulset/<%= baseName.toLowerCase() %>-consul -n ${NAMESPACE} --timeout=120s
<%_ } _%>

<%_ if (messageBrokerKafka) { _%>
  echo "Deploying Kafka (Zookeeper + Kafka)..."
  kubectl apply -f k8s/kafka-statefulset.yml
  echo "Waiting for Zookeeper to be ready..."
  kubectl rollout status statefulset/<%= baseName.toLowerCase() %>-zookeeper -n ${NAMESPACE} --timeout=120s
  echo "Waiting for Kafka to be ready..."
  kubectl rollout status statefulset/<%= baseName.toLowerCase() %>-kafka -n ${NAMESPACE} --timeout=120s
<%_ } _%>

<%_ if (authenticationTypeOauth2) { _%>
  echo "Deploying Keycloak..."
  kubectl apply -f k8s/keycloak-deployment.yml
  echo "Waiting for Keycloak to be ready..."
  kubectl rollout status deployment/<%= baseName.toLowerCase() %>-keycloak -n ${NAMESPACE} --timeout=180s
<%_ } _%>

<%_ if (monitoringPrometheus) { _%>
  echo "Deploying monitoring (Prometheus + Grafana)..."
  kubectl apply -f k8s/monitoring.yml
  kubectl rollout status deployment/<%= baseName.toLowerCase() %>-prometheus -n ${NAMESPACE} --timeout=120s
  kubectl rollout status deployment/<%= baseName.toLowerCase() %>-grafana -n ${NAMESPACE} --timeout=120s
<%_ } _%>

  echo "Deploying application..."
  kubectl apply -f k8s/app-deployment.yml
  kubectl apply -f k8s/app-service.yml

<%_ if (ingressEnabled) { _%>
  echo "Applying Ingress..."
  kubectl apply -f k8s/app-ingress.yml
<%_ } _%>

  echo "Waiting for application to be ready..."
  kubectl rollout status deployment/<%= baseName.toLowerCase() %> -n ${NAMESPACE} --timeout=180s

  echo ""
  echo "Deployment complete!"
  echo "Application: kubectl port-forward svc/<%= baseName.toLowerCase() %> 8080:8080 -n ${NAMESPACE}"
<%_ if (authenticationTypeOauth2) { _%>
  echo "Keycloak:    kubectl port-forward svc/<%= baseName.toLowerCase() %>-keycloak 9080:9080 -n ${NAMESPACE}"
<%_ } _%>
<%_ if (monitoringPrometheus) { _%>
  echo "Prometheus:  kubectl port-forward svc/<%= baseName.toLowerCase() %>-prometheus 9090:9090 -n ${NAMESPACE}"
  echo "Grafana:     kubectl port-forward svc/<%= baseName.toLowerCase() %>-grafana 3000:3000 -n ${NAMESPACE}"
<%_ } _%>

elif [ "${ACTION}" = "delete" ]; then
  echo "Deleting all resources..."
<%_ if (ingressEnabled) { _%>
  kubectl delete -f k8s/app-ingress.yml --ignore-not-found
<%_ } _%>
  kubectl delete -f k8s/app-service.yml --ignore-not-found
  kubectl delete -f k8s/app-deployment.yml --ignore-not-found
<%_ if (monitoringPrometheus) { _%>
  kubectl delete -f k8s/monitoring.yml --ignore-not-found
<%_ } _%>
<%_ if (authenticationTypeOauth2) { _%>
  kubectl delete -f k8s/keycloak-deployment.yml --ignore-not-found
<%_ } _%>
<%_ if (messageBrokerKafka) { _%>
  kubectl delete -f k8s/kafka-statefulset.yml --ignore-not-found
<%_ } _%>
<%_ if (serviceDiscoveryConsul) { _%>
  kubectl delete -f k8s/consul-statefulset.yml --ignore-not-found
<%_ } _%>
<%_ if (devDatabaseTypePostgresql) { _%>
  kubectl delete -f k8s/postgresql-statefulset.yml --ignore-not-found
<%_ } else if (devDatabaseTypeMysql) { _%>
  kubectl delete -f k8s/mysql-statefulset.yml --ignore-not-found
<%_ } else if (devDatabaseTypeMongodb) { _%>
  kubectl delete -f k8s/mongodb-statefulset.yml --ignore-not-found
<%_ } _%>
  kubectl delete -f k8s/app-configmap.yml --ignore-not-found
  kubectl delete -f k8s/app-secret.yml --ignore-not-found
<%_ if (kubernetesNamespace !== 'default') { _%>
  kubectl delete -f k8s/namespace.yml --ignore-not-found
<%_ } _%>
  echo "All resources deleted."

else
  echo "Usage: $0 [apply|delete]"
  exit 1
fi

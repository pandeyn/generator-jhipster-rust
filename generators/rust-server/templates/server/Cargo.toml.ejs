[package]
name = "<%= rustCrateName %>"
version.workspace = true
edition.workspace = true
authors.workspace = true
license.workspace = true

[[bin]]
name = "<%= rustCrateName %>"
path = "src/main.rs"

[dependencies]
axum.workspace = true
tokio.workspace = true
<%_ if (devDatabaseTypeMongodb) { _%>
mongodb.workspace = true
bson.workspace = true
futures.workspace = true
<%_ } else { _%>
diesel.workspace = true
diesel_migrations.workspace = true
<%_ } _%>
<%_ if (hasBigDecimalFields) { _%>
# Track 1-c.0 fix (2026-05-11): pulled in when an entity field is BigDecimal on
# a SQL scaffold. See workspace Cargo.toml comment for context.
bigdecimal.workspace = true
<%_ } _%>
dotenvy.workspace = true
serde.workspace = true
serde_json.workspace = true
serde_qs.workspace = true
tower.workspace = true
tower-http.workspace = true
tracing.workspace = true
tracing-subscriber.workspace = true
thiserror.workspace = true
chrono.workspace = true
uuid.workspace = true
argon2.workspace = true
rand.workspace = true
jsonwebtoken.workspace = true
validator.workspace = true
<%_ if (authenticationTypeOauth2) { _%>
reqwest.workspace = true
urlencoding.workspace = true
subtle.workspace = true
<%_ } _%>
async-trait.workspace = true
lazy_static.workspace = true
regex.workspace = true
<%_ if (enableSwaggerCodegen) { _%>
utoipa.workspace = true
utoipa-scalar.workspace = true
<%_ } _%>
<%_ if (enableEmail) { _%>
lettre.workspace = true
tera.workspace = true
<%_ } _%>
<%_ if (serviceDiscoveryConsul) { _%>
hostname.workspace = true
base64.workspace = true
<%_ if (!authenticationTypeOauth2) { _%>
reqwest.workspace = true
urlencoding.workspace = true
<%_ } _%>
<%_ } _%>
<%_ if (externalConfig) { _%>
serde_yaml.workspace = true
tokio-util.workspace = true
<%_ } _%>
<%_ if (messageBrokerKafka) { _%>
rdkafka.workspace = true
tokio-stream.workspace = true
<%_ if (!devDatabaseTypeMongodb) { _%>
futures.workspace = true
<%_ } _%>
<%_ } _%>
<%_ if (monitoringPrometheus) { _%>
axum-prometheus.workspace = true
metrics.workspace = true
metrics-exporter-prometheus.workspace = true
<%_ } _%>
<%_ if (distributedTracingAny) { _%>
opentelemetry.workspace = true
opentelemetry_sdk.workspace = true
tracing-opentelemetry.workspace = true
<%_ if (distributedTracingZipkin) { _%>
opentelemetry-zipkin.workspace = true
<%_ if (!authenticationTypeOauth2 && !serviceDiscoveryConsul && !circuitBreakerEnabled) { _%>
reqwest.workspace = true
<%_ } _%>
<%_ } else if (distributedTracingJaeger) { _%>
opentelemetry-otlp.workspace = true
<%_ } _%>
<%_ } _%>
<%_ if (circuitBreakerEnabled && !authenticationTypeOauth2 && !serviceDiscoveryConsul) { _%>
reqwest.workspace = true
<%_ } _%>

[dev-dependencies]
axum-test = "14"
tempfile = "3"
# Phase 2a (2026-05-11): parametrized test cases for user_service sort
# branches. Documented decision (plan doc, locked 2026-05-10): rstest over
# 17 separate small `#[test]` functions sharing identical fixture setup —
# 80% less source-line count for no readability loss.
rstest = "0.21"
<%_ if (circuitBreakerEnabled) { _%>
# Phase 2c (v1.0.1 plan, locked decision #2): HTTP server mock for
# resilient_http_client tests. Same dep covers Phase 3a (consul + vault
# wiremock tests). Clean MockServer API with body/header/query matchers;
# ~5M downloads, MIT/Apache-2.0.
wiremock = "0.6"
<%_ } _%>

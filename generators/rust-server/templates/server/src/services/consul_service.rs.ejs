/// Service registration payload for Consul
#[derive(Debug, Serialize)]
#[serde(rename_all = "PascalCase")]
struct ServiceRegistration {
    #[serde(rename = "ID")]
    id: String,
    name: String,
    tags: Vec<String>,
    address: String,
    port: u16,
    check: HealthCheck,
    meta: HashMap<String, String>,
}

/// Health check configuration for Consul
#[derive(Debug, Serialize)]
#[serde(rename_all = "PascalCase")]
struct HealthCheck {
    #[serde(rename = "HTTP")]
    http: String,
    interval: String,
    timeout: String,
    deregister_critical_service_after: String,
}

/// Service instance information from Consul
#[derive(Debug, Deserialize, Clone)]
#[serde(rename_all = "PascalCase")]
pub struct ServiceInstance {
    #[serde(rename = "ID")]
    pub id: String,
    pub service: String,
    pub tags: Vec<String>,
    pub address: String,
    pub port: u16,
    pub meta: Option<HashMap<String, String>>,
}

/// Consul service for managing service registration and discovery
#[derive(Clone)]
pub struct ConsulService {
    config: ConsulConfig,
    client: Client,
    /// Cache of discovered services (service_name -> instances)
    service_cache: Arc<RwLock<HashMap<String, Vec<ServiceInstance>>>>,
<%_ if (circuitBreakerEnabled) { _%>
    /// Optional circuit breaker for resilient Consul communication
    circuit_breaker: Option<Arc<CircuitBreakerService>>,
<%_ } _%>
}

<%_ if (circuitBreakerEnabled) { _%>
/// Circuit breaker service name for Consul operations
const CONSUL_CIRCUIT_BREAKER_NAME: &str = "consul";

<%_ } _%>
impl ConsulService {
    /// Create a new Consul service instance
<%_ if (circuitBreakerEnabled) { _%>
    pub fn new(config: ConsulConfig, circuit_breaker: Option<Arc<CircuitBreakerService>>) -> Self {
<%_ } else { _%>
    pub fn new(config: ConsulConfig) -> Self {
<%_ } _%>
        let mut headers = reqwest::header::HeaderMap::new();

        // Add ACL token header if configured
        if let Some(ref token) = config.acl_token {
            headers.insert(
                "X-Consul-Token",
                reqwest::header::HeaderValue::from_str(token)
                    .expect("Invalid ACL token"),
            );
        }

        let client = Client::builder()
            .default_headers(headers)
            .timeout(std::time::Duration::from_secs(10))
            .build()
            .expect("Failed to create HTTP client for Consul");

        Self {
            config,
            client,
            service_cache: Arc::new(RwLock::new(HashMap::new())),
<%_ if (circuitBreakerEnabled) { _%>
            circuit_breaker,
<%_ } _%>
        }
    }

<%_ if (circuitBreakerEnabled) { _%>
    /// Execute an HTTP request with optional circuit breaker protection
    async fn execute_with_circuit_breaker<F, Fut, T>(
        &self,
        operation: &str,
        f: F,
    ) -> Result<T, ConsulError>
    where
        F: FnOnce() -> Fut,
        Fut: std::future::Future<Output = Result<T, ConsulError>>,
    {
        match &self.circuit_breaker {
            Some(cb) if cb.is_enabled() => {
                cb.execute(CONSUL_CIRCUIT_BREAKER_NAME, f)
                    .await
                    .map_err(|e| match e {
                        CircuitBreakerError::CircuitOpen(svc) => {
                            warn!("Circuit breaker open for Consul {} operation", operation);
                            ConsulError::CircuitBreakerOpen(format!(
                                "Circuit breaker open for service '{}' during {} operation",
                                svc, operation
                            ))
                        }
                        CircuitBreakerError::HalfOpenRejected(svc) => {
                            ConsulError::CircuitBreakerOpen(format!(
                                "Circuit breaker in half-open state, request rejected for service '{}' during {} operation",
                                svc, operation
                            ))
                        }
                        CircuitBreakerError::Timeout => {
                            ConsulError::ConnectionError(format!(
                                "Request timed out during {} operation",
                                operation
                            ))
                        }
                        CircuitBreakerError::RequestFailed(msg) => {
                            ConsulError::ConnectionError(msg)
                        }
                        CircuitBreakerError::NotEnabled => {
                            // This shouldn't happen since we check is_enabled(), but handle it
                            panic!("Circuit breaker not enabled but was called")
                        }
                    })
            }
            _ => f().await,
        }
    }

<%_ } _%>
    /// Register this service instance with Consul
    ///
    /// # Arguments
    /// * `register_address` - The address to register with Consul for service discovery (how other services find this one)
    /// * `app_port` - The port the service is listening on
    ///
    /// Note: The health check URL uses `config.health_check_host` which defaults to `localhost`.
    /// This ensures Consul can reach the health endpoint when running on the same host.
    pub async fn register_service(&self, register_address: &str, app_port: u16) -> Result<(), ConsulError> {
        if !self.config.register_service {
            info!("Service registration disabled, skipping Consul registration");
            return Ok(());
        }

        // Use health_check_host from config for the health check URL
        // This defaults to localhost which works when Consul runs on the same host
        let health_check_url = format!(
            "http://{}:{}/api/health",
            self.config.health_check_host, app_port
        );

        let mut meta = HashMap::new();
        meta.insert("version".to_string(), env!("CARGO_PKG_VERSION").to_string());
        meta.insert("framework".to_string(), "axum".to_string());

        let registration = ServiceRegistration {
            id: self.config.service_id.clone(),
            name: self.config.service_name.clone(),
            tags: self.config.service_tags.clone(),
            address: register_address.to_string(),
            port: app_port,
            check: HealthCheck {
                http: health_check_url,
                interval: format!("{}s", self.config.health_check_interval),
                timeout: "5s".to_string(),
                deregister_critical_service_after: "30s".to_string(),
            },
            meta,
        };

        let url = format!("{}/v1/agent/service/register", self.config.consul_url());

        info!(
            "Registering service '{}' with Consul at {}",
            self.config.service_name,
            self.config.consul_url()
        );

<%_ if (circuitBreakerEnabled) { _%>
        let client = self.client.clone();
        let service_name = self.config.service_name.clone();
        let service_id = self.config.service_id.clone();

        self.execute_with_circuit_breaker("register", || async {
            let response = client
                .put(&url)
                .json(&registration)
                .send()
                .await
                .map_err(|e| ConsulError::ConnectionError(e.to_string()))?;

            if response.status().is_success() {
                info!(
                    "Successfully registered service '{}' (ID: {}) with Consul",
                    service_name, service_id
                );
                Ok(())
            } else {
                let status = response.status();
                let body = response.text().await.unwrap_or_default();
                error!(
                    "Failed to register service with Consul: {} - {}",
                    status, body
                );
                Err(ConsulError::RegistrationError(format!(
                    "HTTP {}: {}",
                    status, body
                )))
            }
        }).await
<%_ } else { _%>
        let response = self
            .client
            .put(&url)
            .json(&registration)
            .send()
            .await
            .map_err(|e| ConsulError::ConnectionError(e.to_string()))?;

        if response.status().is_success() {
            info!(
                "Successfully registered service '{}' (ID: {}) with Consul",
                self.config.service_name, self.config.service_id
            );
            Ok(())
        } else {
            let status = response.status();
            let body = response.text().await.unwrap_or_default();
            error!(
                "Failed to register service with Consul: {} - {}",
                status, body
            );
            Err(ConsulError::RegistrationError(format!(
                "HTTP {}: {}",
                status, body
            )))
        }
<%_ } _%>
    }


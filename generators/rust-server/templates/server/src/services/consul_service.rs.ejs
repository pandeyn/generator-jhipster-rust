                .respond_with(ResponseTemplate::new(404))
                .expect(1)
                .mount(&server)
                .await;

            let svc = ConsulService::new(cfg_for(&server), None);
            let (value, index) = svc.watch_config("gone", 0).await.unwrap();
            assert!(value.is_none());
            // No X-Consul-Index header → unwrap_or(0).
            assert_eq!(index, 0);
        }

        #[tokio::test]
        async fn test_watch_config_5xx_returns_config_error() {
            let server = MockServer::start().await;
            Mock::given(method("GET"))
                .and(path("/v1/kv/broken"))
                .respond_with(ResponseTemplate::new(500))
                .expect(1)
                .mount(&server)
                .await;

            let svc = ConsulService::new(cfg_for(&server), None);
            let result = svc.watch_config("broken", 0).await;
            assert!(
                matches!(result, Err(ConsulError::ConfigError(_))),
                "expected ConfigError, got {:?}",
                result.err()
            );
        }
    }

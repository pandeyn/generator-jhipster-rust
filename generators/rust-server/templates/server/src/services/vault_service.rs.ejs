    #[test]
    fn test_vault_error_display() {
        assert_eq!(
            VaultError::ConnectionError("timeout".to_string()).to_string(),
            "Connection error: timeout"
        );
        assert_eq!(
            VaultError::AuthError("invalid token".to_string()).to_string(),
            "Authentication error: invalid token"
        );
        assert_eq!(
            VaultError::PermissionError("denied".to_string()).to_string(),
            "Permission denied: denied"
        );
        assert_eq!(
            VaultError::ReadError("read fail".to_string()).to_string(),
            "Secret read error: read fail"
        );
        assert_eq!(
            VaultError::NotFound("missing".to_string()).to_string(),
            "Not found: missing"
        );
        assert_eq!(
            VaultError::ParseError("bad json".to_string()).to_string(),
            "Parse error: bad json"
        );

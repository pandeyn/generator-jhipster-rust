//! Distributed tracing configuration for <%= baseName %>
//!
//! This module provides configuration for OpenTelemetry distributed tracing.
<%_ if (distributedTracingZipkin) { _%>
//! Traces are exported to Zipkin at the configured endpoint.
<%_ } else if (distributedTracingJaeger) { _%>
//! Traces are exported to Jaeger via OTLP at the configured endpoint.
<%_ } _%>

use opentelemetry::trace::TracerProvider as _;
use opentelemetry_sdk::trace::{TracerProvider, Sampler};
use tracing_opentelemetry::OpenTelemetryLayer;
use tracing_subscriber::Registry;
<%_ if (distributedTracingJaeger) { _%>
use opentelemetry_otlp::WithExportConfig;
<%_ } _%>

/// Configuration for distributed tracing
#[derive(Debug, Clone)]
pub struct TracingConfig {
    /// Whether distributed tracing is enabled
    pub enabled: bool,
    /// The service name reported in traces
    pub service_name: String,
    /// The tracing backend endpoint
    pub endpoint: String,
    /// The sampling ratio (0.0 to 1.0)
    pub sample_ratio: f64,
}

impl TracingConfig {
    /// Load tracing configuration from environment variables
    ///
    /// Environment variables:
    /// - `TRACING_ENABLED`: Enable/disable tracing (default: true)
    /// - `TRACING_SERVICE_NAME`: Service name in traces (default: <%= baseName %>)
    /// - `TRACING_ENDPOINT`: Tracing backend endpoint
<%_ if (distributedTracingZipkin) { _%>
    ///   (default: http://localhost:9411/api/v2/spans)
<%_ } else if (distributedTracingJaeger) { _%>
    ///   (default: http://localhost:4317)
<%_ } _%>
    /// - `TRACING_SAMPLE_RATIO`: Sampling ratio 0.0-1.0 (default: 1.0)
    pub fn from_env() -> Self {
        Self {
            enabled: std::env::var("TRACING_ENABLED")
                .map(|v| v.to_lowercase() == "true" || v == "1")
                .unwrap_or(true),
            service_name: std::env::var("TRACING_SERVICE_NAME")
                .unwrap_or_else(|_| "<%= baseName %>".to_string()),
            endpoint: std::env::var("TRACING_ENDPOINT")
<%_ if (distributedTracingZipkin) { _%>
                .unwrap_or_else(|_| "http://localhost:9411/api/v2/spans".to_string()),
<%_ } else if (distributedTracingJaeger) { _%>
                .unwrap_or_else(|_| "http://localhost:4317".to_string()),
<%_ } _%>
            sample_ratio: std::env::var("TRACING_SAMPLE_RATIO")
                .ok()
                .and_then(|v| v.parse::<f64>().ok())
                .unwrap_or(1.0),
        }
    }

    /// Initialize the OpenTelemetry tracer and return a tracing layer
    ///
    /// Returns `Some(layer)` if tracing is enabled, `None` otherwise.
    pub fn init_tracer(&self) -> Option<OpenTelemetryLayer<Registry, opentelemetry_sdk::trace::Tracer>> {
        if !self.enabled {
            return None;
        }

        let sampler = if (self.sample_ratio - 1.0).abs() < f64::EPSILON {
            Sampler::AlwaysOn
        } else if self.sample_ratio <= 0.0 {
            Sampler::AlwaysOff
        } else {
            Sampler::TraceIdRatioBased(self.sample_ratio)
        };

<%_ if (distributedTracingZipkin) { _%>
        let exporter = opentelemetry_zipkin::new_pipeline()
            .with_service_name(&self.service_name)
            .with_collector_endpoint(&self.endpoint)
            .init_exporter()
            .expect("Failed to initialize Zipkin exporter");

        let provider = TracerProvider::builder()
            .with_sampler(sampler)
            .with_batch_exporter(exporter, opentelemetry_sdk::runtime::Tokio)
            .build();
<%_ } else if (distributedTracingJaeger) { _%>
        let exporter = opentelemetry_otlp::SpanExporter::builder()
            .with_tonic()
            .with_endpoint(&self.endpoint)
            .build()
            .expect("Failed to initialize OTLP exporter");

        let provider = TracerProvider::builder()
            .with_sampler(sampler)
            .with_batch_exporter(exporter, opentelemetry_sdk::runtime::Tokio)
            .build();
<%_ } _%>

        let tracer = provider.tracer(self.service_name.clone());
        opentelemetry::global::set_tracer_provider(provider);

        Some(tracing_opentelemetry::layer().with_tracer(tracer))
    }
}

/// Shutdown the OpenTelemetry tracer provider, flushing any pending spans
pub fn shutdown_tracer() {
    opentelemetry::global::shutdown_tracer_provider();
}

// Phase 3c (2026-06-07): coverage of from_env() + init_tracer's
// disabled-branch + struct construction. Locked decision #5 caps the
// per-file target at >=30% because init_tracer's exporter init does
// real work at file-load time that can't be exercised without a real
// OTLP/Zipkin collector. Mutex serializes env-var tests (locked
// convention 2026-05-11); the rest of the suite stays parallel.
#[cfg(test)]
mod tests {
    use super::*;
    use std::sync::Mutex;

    static ENV_LOCK: Mutex<()> = Mutex::new(());

    const ENV_VARS: &[&str] = &[
        "TRACING_ENABLED",
        "TRACING_SERVICE_NAME",
        "TRACING_ENDPOINT",
        "TRACING_SAMPLE_RATIO",
    ];

    fn clear_env() {
        for var in ENV_VARS {
            std::env::remove_var(var);
        }
    }

    #[test]
    fn test_from_env_returns_defaults_when_no_vars_set() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();

        let cfg = TracingConfig::from_env();
        assert!(cfg.enabled, "enabled should default to true");
        assert_eq!(cfg.service_name, "<%= baseName %>");
<%_ if (distributedTracingZipkin) { _%>
        assert_eq!(cfg.endpoint, "http://localhost:9411/api/v2/spans");
<%_ } else if (distributedTracingJaeger) { _%>
        assert_eq!(cfg.endpoint, "http://localhost:4317");
<%_ } _%>
        assert!((cfg.sample_ratio - 1.0).abs() < f64::EPSILON);

        clear_env();
    }

    #[test]
    fn test_from_env_reads_tracing_enabled_false_via_string() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();
        std::env::set_var("TRACING_ENABLED", "false");

        let cfg = TracingConfig::from_env();
        assert!(!cfg.enabled);

        clear_env();
    }

    #[test]
    fn test_from_env_reads_tracing_enabled_via_one() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();
        std::env::set_var("TRACING_ENABLED", "1");

        let cfg = TracingConfig::from_env();
        assert!(cfg.enabled, "TRACING_ENABLED=1 should enable tracing");

        clear_env();
    }

    #[test]
    fn test_from_env_reads_tracing_enabled_case_insensitive() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();
        std::env::set_var("TRACING_ENABLED", "TRUE");

        let cfg = TracingConfig::from_env();
        assert!(cfg.enabled, "TRACING_ENABLED=TRUE should enable tracing (case-insensitive)");

        clear_env();
    }

    #[test]
    fn test_from_env_reads_tracing_enabled_garbage_disables() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();
        std::env::set_var("TRACING_ENABLED", "yes-please");

        let cfg = TracingConfig::from_env();
        // The closure returns false because "yes-please" != "true" and != "1".
        assert!(!cfg.enabled, "non-true/1 values should disable tracing");

        clear_env();
    }

    #[test]
    fn test_from_env_reads_service_name_override() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();
        std::env::set_var("TRACING_SERVICE_NAME", "custom-svc");

        let cfg = TracingConfig::from_env();
        assert_eq!(cfg.service_name, "custom-svc");

        clear_env();
    }

    #[test]
    fn test_from_env_reads_endpoint_override() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();
        std::env::set_var("TRACING_ENDPOINT", "http://tracer.internal:9000/spans");

        let cfg = TracingConfig::from_env();
        assert_eq!(cfg.endpoint, "http://tracer.internal:9000/spans");

        clear_env();
    }

    #[test]
    fn test_from_env_reads_sample_ratio_valid() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();
        std::env::set_var("TRACING_SAMPLE_RATIO", "0.25");

        let cfg = TracingConfig::from_env();
        assert!((cfg.sample_ratio - 0.25).abs() < f64::EPSILON);

        clear_env();
    }

    #[test]
    fn test_from_env_reads_sample_ratio_malformed_falls_back_to_default() {
        let _guard = ENV_LOCK.lock().unwrap();
        clear_env();
        std::env::set_var("TRACING_SAMPLE_RATIO", "not-a-float");

        let cfg = TracingConfig::from_env();
        // parse::<f64>().ok() yields None on garbage; unwrap_or(1.0) restores default.
        assert!((cfg.sample_ratio - 1.0).abs() < f64::EPSILON);

        clear_env();
    }

    #[test]
    fn test_init_tracer_returns_none_when_disabled() {
        // No env access, no global state — pure short-circuit on the
        // self.enabled check. The exporter init below this branch is
        // explicitly NOT exercised per locked decision #5 (needs a real
        // OTLP/Zipkin collector).
        let cfg = TracingConfig {
            enabled: false,
            service_name: "test-svc".to_string(),
            endpoint: "http://example.invalid".to_string(),
            sample_ratio: 1.0,
        };
        assert!(cfg.init_tracer().is_none());
    }

    #[test]
    fn test_tracing_config_struct_construction_and_clone() {
        // Covers the Debug + Clone derives on TracingConfig.
        let cfg = TracingConfig {
            enabled: true,
            service_name: "svc".to_string(),
            endpoint: "http://example.invalid".to_string(),
            sample_ratio: 0.5,
        };
        let cloned = cfg.clone();
        assert_eq!(cloned.service_name, "svc");
        assert!(format!("{:?}", cfg).contains("TracingConfig"));
    }
}

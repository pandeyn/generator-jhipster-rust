use std::env;

/// Configuration for Consul service discovery and configuration management
#[derive(Clone, Debug)]
pub struct ConsulConfig {
    /// Consul server host (default: localhost)
    pub host: String,
    /// Consul server port (default: 8500)
    pub port: u16,
    /// Service name to register with Consul
    pub service_name: String,
    /// Service ID (unique identifier for this instance)
    pub service_id: String,
    /// Tags to associate with the service
    pub service_tags: Vec<String>,
    /// Health check interval in seconds
    pub health_check_interval: u64,
    /// Whether to enable service registration
    pub register_service: bool,
    /// Whether to enable configuration loading from Consul KV
    pub enable_config: bool,
    /// ACL token for Consul (optional)
    pub acl_token: Option<String>,
    /// Key prefix for configuration in Consul KV store
    pub config_key_prefix: String,
    /// Host address for health check endpoint (default: localhost)
    /// This should be an address that Consul can use to reach this service's health endpoint
    pub health_check_host: String,
    /// Configuration profile (e.g., dev, staging, prod)
    /// Determines which profile-specific config to load from Consul KV
    pub config_profile: String,
    /// Whether to enable config watching for hot-reload
    pub watch_enabled: bool,
    /// Interval in seconds for config watch long-polling
    pub watch_interval: u64,
}

impl ConsulConfig {
    pub fn from_env() -> Self {
        let service_name = env::var("CONSUL_SERVICE_NAME")
            .unwrap_or_else(|_| "<%= baseName.toLowerCase() %>".to_string());

        // Generate a unique instance ID using hostname and random suffix
        let instance_id = env::var("CONSUL_SERVICE_ID").unwrap_or_else(|_| {
            let hostname = hostname::get()
                .map(|h| h.to_string_lossy().to_string())
                .unwrap_or_else(|_| "unknown".to_string());
            let random_suffix: u32 = rand::random();
            format!("{}-{}-{:08x}", service_name, hostname, random_suffix)
        });

        let tags = env::var("CONSUL_SERVICE_TAGS")
            .map(|t| t.split(',').map(|s| s.trim().to_string()).collect())
            .unwrap_or_else(|_| vec![
                format!("version={}", env!("CARGO_PKG_VERSION")),
                format!("env={}", env::var("APP_ENV").unwrap_or_else(|_| "development".to_string())),
            ]);

        Self {
            host: env::var("CONSUL_HOST").unwrap_or_else(|_| "localhost".to_string()),
            port: env::var("CONSUL_PORT")
                .unwrap_or_else(|_| "8500".to_string())
                .parse()
                .expect("CONSUL_PORT must be a valid port number"),
            service_name,
            service_id: instance_id,
            service_tags: tags,
            health_check_interval: env::var("CONSUL_HEALTH_CHECK_INTERVAL")
                .unwrap_or_else(|_| "10".to_string())
                .parse()
                .expect("CONSUL_HEALTH_CHECK_INTERVAL must be a valid number"),
            register_service: env::var("CONSUL_REGISTER_SERVICE")
                .map(|v| v.to_lowercase() == "true")
                .unwrap_or(true),
            enable_config: env::var("CONSUL_ENABLE_CONFIG")
                .map(|v| v.to_lowercase() == "true")
                .unwrap_or(true),
            acl_token: env::var("CONSUL_ACL_TOKEN").ok(),
            config_key_prefix: env::var("CONSUL_CONFIG_KEY_PREFIX")
                .unwrap_or_else(|_| "config/<%= baseName.toLowerCase() %>".to_string()),
            // Use localhost by default for health checks - this works when Consul runs on the same host
            // Override with CONSUL_HEALTH_CHECK_HOST when Consul runs remotely or in a different container
            health_check_host: env::var("CONSUL_HEALTH_CHECK_HOST")
                .unwrap_or_else(|_| "localhost".to_string()),
            config_profile: env::var("APP_PROFILE")
                .unwrap_or_else(|_| "dev".to_string()),
            watch_enabled: env::var("CONSUL_CONFIG_WATCH_ENABLED")
                .map(|v| v.to_lowercase() == "true")
                .unwrap_or(true),
            watch_interval: env::var("CONSUL_CONFIG_WATCH_INTERVAL")
                .unwrap_or_else(|_| "55".to_string())
                .parse()
                .expect("CONSUL_CONFIG_WATCH_INTERVAL must be a valid number"),
        }
    }

    /// Get the full Consul URL
    pub fn consul_url(&self) -> String {
        format!("http://{}:{}", self.host, self.port)
    }

    /// Get the base config key in Consul KV (shared across all profiles)
    pub fn config_base_key(&self) -> String {
        format!("{}/application", self.config_key_prefix)
    }

    /// Get the profile-specific config key in Consul KV
    pub fn config_profile_key(&self) -> String {
        format!("{}/application-{}", self.config_key_prefix, self.config_profile)
    }
}

// Track 1 Phase 1b (2026-05-11): from_env() coverage. Mutex serializes
// env-var tests; rest of the suite stays parallel.
#[cfg(test)]
mod tests {
    use super::*;
    use std::sync::Mutex;

    static ENV_LOCK: Mutex<()> = Mutex::new(());

    fn clear_consul_env() {
        for k in [
            "CONSUL_HOST",
            "CONSUL_PORT",
            "CONSUL_SERVICE_NAME",
            "CONSUL_SERVICE_ID",
            "CONSUL_SERVICE_TAGS",
            "CONSUL_HEALTH_CHECK_INTERVAL",
            "CONSUL_REGISTER_SERVICE",
            "CONSUL_ENABLE_CONFIG",
            "CONSUL_ACL_TOKEN",
            "CONSUL_CONFIG_KEY_PREFIX",
            "CONSUL_HEALTH_CHECK_HOST",
            "CONSUL_CONFIG_WATCH_ENABLED",
            "CONSUL_CONFIG_WATCH_INTERVAL",
            "APP_ENV",
            "APP_PROFILE",
        ] {
            std::env::remove_var(k);
        }
    }

    #[test]
    fn test_from_env_uses_documented_defaults() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        let cfg = ConsulConfig::from_env();
        assert_eq!(cfg.host, "localhost");
        assert_eq!(cfg.port, 8500);
        assert_eq!(cfg.health_check_interval, 10);
        assert!(cfg.register_service);
        assert!(cfg.enable_config);
        assert!(cfg.acl_token.is_none());
        assert_eq!(cfg.health_check_host, "localhost");
        assert_eq!(cfg.config_profile, "dev");
        assert!(cfg.watch_enabled);
        assert_eq!(cfg.watch_interval, 55);
        // service_name and config_key_prefix derive from baseName — assert
        // shape, not exact value, for cross-scaffold portability.
        assert!(!cfg.service_name.is_empty());
        assert!(cfg.config_key_prefix.starts_with("config/"));
        // service_id is auto-generated (hostname + random); just assert non-empty.
        assert!(!cfg.service_id.is_empty());
        // default tags include version=... and env=... — exactly two entries.
        assert_eq!(cfg.service_tags.len(), 2);
        assert!(cfg.service_tags.iter().any(|t| t.starts_with("version=")));
        assert!(cfg.service_tags.iter().any(|t| t.starts_with("env=")));
    }

    #[test]
    fn test_from_env_reads_explicit_host_and_port() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_HOST", "consul.internal");
        std::env::set_var("CONSUL_PORT", "9999");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert_eq!(cfg.host, "consul.internal");
        assert_eq!(cfg.port, 9999);
    }

    #[test]
    fn test_from_env_service_name_override() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_SERVICE_NAME", "my-svc");
        std::env::set_var("CONSUL_SERVICE_ID", "my-svc-1");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert_eq!(cfg.service_name, "my-svc");
        assert_eq!(cfg.service_id, "my-svc-1");
    }

    #[test]
    fn test_from_env_tags_split_and_trim() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_SERVICE_TAGS", "prod, v1 ,canary");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert_eq!(cfg.service_tags, vec!["prod".to_string(), "v1".to_string(), "canary".to_string()]);
    }

    #[test]
    fn test_from_env_default_tags_include_app_env() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("APP_ENV", "production");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert!(cfg.service_tags.iter().any(|t| t == "env=production"));
    }

    #[test]
    fn test_from_env_register_service_disabled() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_REGISTER_SERVICE", "false");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert!(!cfg.register_service);
    }

    #[test]
    fn test_from_env_enable_config_disabled() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_ENABLE_CONFIG", "false");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert!(!cfg.enable_config);
    }

    #[test]
    fn test_from_env_register_service_case_insensitive() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_REGISTER_SERVICE", "TRUE");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert!(cfg.register_service);
    }

    #[test]
    fn test_from_env_acl_token_some_when_set() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_ACL_TOKEN", "secret-token");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert_eq!(cfg.acl_token.as_deref(), Some("secret-token"));
    }

    #[test]
    fn test_from_env_config_key_prefix_override() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_CONFIG_KEY_PREFIX", "config/custom");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert_eq!(cfg.config_key_prefix, "config/custom");
    }

    #[test]
    fn test_from_env_health_check_host_override() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_HEALTH_CHECK_HOST", "10.0.0.5");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert_eq!(cfg.health_check_host, "10.0.0.5");
    }

    #[test]
    fn test_from_env_app_profile_reads_app_profile_var() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("APP_PROFILE", "staging");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert_eq!(cfg.config_profile, "staging");
    }

    #[test]
    fn test_from_env_watch_settings() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_CONFIG_WATCH_ENABLED", "false");
        std::env::set_var("CONSUL_CONFIG_WATCH_INTERVAL", "30");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert!(!cfg.watch_enabled);
        assert_eq!(cfg.watch_interval, 30);
    }

    #[test]
    fn test_from_env_health_check_interval_custom() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_consul_env();
        std::env::set_var("CONSUL_HEALTH_CHECK_INTERVAL", "60");
        let cfg = ConsulConfig::from_env();
        clear_consul_env();
        assert_eq!(cfg.health_check_interval, 60);
    }

    #[test]
    fn test_consul_url() {
        let config = ConsulConfig {
            host: "localhost".to_string(),
            port: 8500,
            service_name: "test-service".to_string(),
            service_id: "test-service-1".to_string(),
            service_tags: vec!["test".to_string()],
            health_check_interval: 10,
            register_service: true,
            enable_config: true,
            acl_token: None,
            config_key_prefix: "config/test".to_string(),
            health_check_host: "localhost".to_string(),
            config_profile: "dev".to_string(),
            watch_enabled: true,
            watch_interval: 55,
        };
        assert_eq!(config.consul_url(), "http://localhost:8500");
    }

    #[test]
    fn test_config_keys() {
        let config = ConsulConfig {
            host: "localhost".to_string(),
            port: 8500,
            service_name: "test-service".to_string(),
            service_id: "test-service-1".to_string(),
            service_tags: vec!["test".to_string()],
            health_check_interval: 10,
            register_service: true,
            enable_config: true,
            acl_token: None,
            config_key_prefix: "config/test".to_string(),
            health_check_host: "localhost".to_string(),
            config_profile: "prod".to_string(),
            watch_enabled: true,
            watch_interval: 55,
        };
        assert_eq!(config.config_base_key(), "config/test/application");
        assert_eq!(config.config_profile_key(), "config/test/application-prod");
    }

    #[test]
    fn test_consul_config_clone() {
        let config = ConsulConfig {
            host: "consul.example.com".to_string(),
            port: 8500,
            service_name: "my-service".to_string(),
            service_id: "my-service-abc123".to_string(),
            service_tags: vec!["prod".to_string(), "v1".to_string()],
            health_check_interval: 15,
            register_service: true,
            enable_config: true,
            acl_token: Some("secret-token".to_string()),
            config_key_prefix: "config/my-service".to_string(),
            health_check_host: "localhost".to_string(),
            config_profile: "prod".to_string(),
            watch_enabled: true,
            watch_interval: 55,
        };
        let cloned = config.clone();
        assert_eq!(cloned.host, config.host);
        assert_eq!(cloned.service_name, config.service_name);
        assert_eq!(cloned.acl_token, config.acl_token);
    }
}

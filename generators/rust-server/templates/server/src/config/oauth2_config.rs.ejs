//! OAuth2/OIDC Configuration for Keycloak/Okta

use serde::Deserialize;

/// OAuth2/OIDC configuration loaded from environment variables
#[derive(Debug, Clone, Deserialize)]
pub struct OAuth2Config {
    /// The OIDC issuer URI (e.g., http://localhost:9080/realms/jhipster)
    pub issuer_uri: String,
    /// OAuth2 client ID
    pub client_id: String,
    /// OAuth2 client secret (optional for public clients)
    pub client_secret: Option<String>,
    /// JWKS URI for fetching public keys
    pub jwks_uri: String,
    /// Authorization endpoint
    pub authorization_endpoint: String,
    /// Token endpoint
    pub token_endpoint: String,
    /// UserInfo endpoint
    pub userinfo_endpoint: String,
    /// End session (logout) endpoint
    pub end_session_endpoint: String,
}

impl OAuth2Config {
    /// Creates OAuth2 configuration from environment variables
    ///
    /// Required environment variables:
    /// - OIDC_ISSUER_URI: The OIDC issuer URI (browser-facing; also the `iss`
    ///   claim the server validates against)
    /// - OIDC_CLIENT_ID: The OAuth2 client ID
    ///
    /// Optional environment variables:
    /// - OIDC_CLIENT_SECRET: The OAuth2 client secret
    /// - OIDC_INTERNAL_URI: Server-side base URL for OIDC endpoints the app
    ///   calls directly (token exchange, JWKS, userinfo, end_session). Falls
    ///   back to OIDC_ISSUER_URI when unset. The split is needed for docker
    ///   compose: the browser resolves Keycloak at http://localhost:9080 while
    ///   the app container reaches it at http://keycloak:9080. Keycloak's
    ///   KC_HOSTNAME pins the `iss` claim so token validation still matches.
    ///   Bug #18 fix from 1-a.5.3.
    ///
    /// authorization_endpoint stays on issuer_uri because the browser follows
    /// it. jwks_uri / token_endpoint / userinfo_endpoint / end_session_endpoint
    /// are derived from internal_uri because the server calls them directly.
    pub fn from_env() -> Self {
        let issuer_uri = std::env::var("OIDC_ISSUER_URI")
            .unwrap_or_else(|_| "http://localhost:9080/realms/jhipster".to_string());

        let internal_uri = std::env::var("OIDC_INTERNAL_URI").unwrap_or_else(|_| issuer_uri.clone());

        let client_id = std::env::var("OIDC_CLIENT_ID")
            .unwrap_or_else(|_| "web_app".to_string());

        let client_secret = std::env::var("OIDC_CLIENT_SECRET").ok();

        // Derive endpoints. Two base URLs: external (browser) for auth, internal
        // (server) for the rest.
        let external_base = issuer_uri.trim_end_matches('/');
        let internal_base = internal_uri.trim_end_matches('/');
        let is_okta = external_base.contains("okta");

        // Endpoint categorization:
        //   - authorization_endpoint + end_session_endpoint are browser-facing
        //     (server returns these in redirects / JSON payloads for the
        //     browser to follow), so they use the external base.
        //   - jwks_uri + token_endpoint + userinfo_endpoint are server-internal
        //     (the app calls them directly), so they use the internal base.
        //   - Bug #19 follow-on from 1-a.5.3: end_session_endpoint was on the
        //     internal base, causing the browser to hang following
        //     http://keycloak:9080/... after logout (60s page-load timeout
        //     in the cypress logout spec).
        let (jwks_uri, authorization_endpoint, token_endpoint, userinfo_endpoint, end_session_endpoint) = if is_okta {
            (
                format!("{}/v1/keys", internal_base),
                format!("{}/v1/authorize", external_base),
                format!("{}/v1/token", internal_base),
                format!("{}/v1/userinfo", internal_base),
                format!("{}/v1/logout", external_base),
            )
        } else {
            (
                format!("{}/protocol/openid-connect/certs", internal_base),
                format!("{}/protocol/openid-connect/auth", external_base),
                format!("{}/protocol/openid-connect/token", internal_base),
                format!("{}/protocol/openid-connect/userinfo", internal_base),
                format!("{}/protocol/openid-connect/logout", external_base),
            )
        };

        Self {
            issuer_uri,
            client_id,
            client_secret,
            jwks_uri,
            authorization_endpoint,
            token_endpoint,
            userinfo_endpoint,
            end_session_endpoint,
        }
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use std::sync::Mutex;

    // Mutex to ensure OAuth2 config tests run serially since they modify env vars
    static ENV_MUTEX: Mutex<()> = Mutex::new(());

    #[test]
    fn test_default_config() {
        let _guard = ENV_MUTEX.lock().unwrap();

        // Clear any existing env vars for test isolation
        std::env::remove_var("OIDC_ISSUER_URI");
        std::env::remove_var("OIDC_INTERNAL_URI");
        std::env::remove_var("OIDC_CLIENT_ID");
        std::env::remove_var("OIDC_CLIENT_SECRET");

        let config = OAuth2Config::from_env();

        assert_eq!(config.issuer_uri, "http://localhost:9080/realms/jhipster");
        assert_eq!(config.client_id, "web_app");
        assert!(config.client_secret.is_none());
        assert!(config.jwks_uri.contains("protocol/openid-connect/certs"));
    }

    #[test]
    fn test_keycloak_endpoints() {
        let _guard = ENV_MUTEX.lock().unwrap();

        std::env::set_var("OIDC_ISSUER_URI", "http://keycloak:9080/realms/test");
        std::env::remove_var("OIDC_INTERNAL_URI");
        std::env::set_var("OIDC_CLIENT_ID", "test_app");

        let config = OAuth2Config::from_env();

        assert_eq!(config.jwks_uri, "http://keycloak:9080/realms/test/protocol/openid-connect/certs");
        assert_eq!(config.authorization_endpoint, "http://keycloak:9080/realms/test/protocol/openid-connect/auth");
        assert_eq!(config.token_endpoint, "http://keycloak:9080/realms/test/protocol/openid-connect/token");

        // Clean up
        std::env::remove_var("OIDC_ISSUER_URI");
        std::env::remove_var("OIDC_CLIENT_ID");
    }

    #[test]
    fn test_split_issuer_and_internal_uri() {
        // Bug #18 fix: in docker compose, the browser-facing issuer URL
        // and the server-side internal URL differ. authorization_endpoint
        // must use the issuer URL (browser follows it); the rest use
        // the internal URL.
        let _guard = ENV_MUTEX.lock().unwrap();

        std::env::set_var("OIDC_ISSUER_URI", "http://localhost:9080/realms/jhipster");
        std::env::set_var("OIDC_INTERNAL_URI", "http://keycloak:9080/realms/jhipster");
        std::env::set_var("OIDC_CLIENT_ID", "web_app");

        let config = OAuth2Config::from_env();

        // Browser-facing.
        assert_eq!(
            config.authorization_endpoint,
            "http://localhost:9080/realms/jhipster/protocol/openid-connect/auth"
        );
        // Server-side (docker network).
        assert_eq!(
            config.token_endpoint,
            "http://keycloak:9080/realms/jhipster/protocol/openid-connect/token"
        );
        assert_eq!(
            config.jwks_uri,
            "http://keycloak:9080/realms/jhipster/protocol/openid-connect/certs"
        );
        assert_eq!(
            config.userinfo_endpoint,
            "http://keycloak:9080/realms/jhipster/protocol/openid-connect/userinfo"
        );
        // Bug #19: end_session_endpoint goes back to the BROWSER (the logout
        // handler emits it in the JSON response for the SPA to navigate to),
        // so it must use the external base. Browser can't resolve `keycloak`.
        assert_eq!(
            config.end_session_endpoint,
            "http://localhost:9080/realms/jhipster/protocol/openid-connect/logout"
        );
        // issuer_uri itself is the browser-facing one (also what's in `iss`).
        assert_eq!(config.issuer_uri, "http://localhost:9080/realms/jhipster");

        std::env::remove_var("OIDC_ISSUER_URI");
        std::env::remove_var("OIDC_INTERNAL_URI");
        std::env::remove_var("OIDC_CLIENT_ID");
    }

    #[test]
    fn test_okta_endpoints() {
        let _guard = ENV_MUTEX.lock().unwrap();

        std::env::set_var("OIDC_ISSUER_URI", "https://dev-12345.okta.com/oauth2/default");
        std::env::remove_var("OIDC_INTERNAL_URI");
        std::env::set_var("OIDC_CLIENT_ID", "okta_app");

        let config = OAuth2Config::from_env();

        assert!(config.jwks_uri.contains("/v1/keys"));
        assert!(config.authorization_endpoint.contains("/v1/authorize"));
        assert!(config.token_endpoint.contains("/v1/token"));

        // Clean up
        std::env::remove_var("OIDC_ISSUER_URI");
        std::env::remove_var("OIDC_CLIENT_ID");
    }
}

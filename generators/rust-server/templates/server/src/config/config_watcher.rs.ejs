    #[test]
    fn test_config_watcher_creation() {
        // Just verify the struct can be constructed
        let remote_config = new_shared_remote_config();
        let cancel_token = CancellationToken::new();
        assert!(!cancel_token.is_cancelled());
        drop(remote_config);
    }


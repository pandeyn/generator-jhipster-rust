        #[tokio::test]
        async fn test_run_watch_error_then_cancel_during_retry_sleep() {
            // First watch endpoint returns 500 — watch_cycle returns Err,
            // run() enters the 10s retry sleep. We cancel mid-sleep; the
            // tokio::select! in the retry arm picks up the cancellation
            // branch and run() returns. Covers the Err branch + the
            // cancel-during-retry arm.
            let server = MockServer::start().await;
            Mock::given(method("GET"))
                .and(path("/v1/kv/config/test/application"))
                .respond_with(ResponseTemplate::new(500).set_body_string("consul down"))
                .mount(&server)
                .await;
            // The profile endpoint shouldn't even get hit (watch_cycle bails
            // after the first watch_config Err). Mount a default 500 just in
            // case.
            Mock::given(method("GET"))
                .and(path("/v1/kv/config/test/application-dev"))
                .respond_with(ResponseTemplate::new(500))
                .mount(&server)
                .await;

            let (consul, consul_cfg) = make_consul(&server).await;
            let remote_config = new_shared_remote_config();
            let cancel = CancellationToken::new();
            let watcher = ConfigWatcher::new(consul, consul_cfg, remote_config, cancel.clone());

            let handle = tokio::spawn(watcher.run());
            // Give it long enough for the first watch_cycle to fail (~few ms)
            // and enter the retry sleep, but well under the 10s retry timer.
            tokio::time::sleep(Duration::from_millis(100)).await;
            cancel.cancel();
            // Without the cancel-during-retry arm we'd block here for ~10s.
            tokio::time::timeout(Duration::from_millis(500), handle)
                .await
                .expect("cancel during retry-sleep should terminate the watcher promptly")
                .expect("watcher task should not panic");
        }


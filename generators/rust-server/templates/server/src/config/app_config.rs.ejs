    fn consul_with<const N: usize>(entries: [(&'static str, &'static str); N]) -> std::collections::HashMap<String, String> {
        entries.iter().map(|(k, v)| (k.to_string(), v.to_string())).collect()
    }

    #[test]
    fn test_from_consul_and_env_uses_defaults_when_both_unset() {
        let _g = ENV_LOCK.lock().unwrap();
        clear_app_env();
        // Required vars (DATABASE_URL, JWT_SECRET) come from consul in this test.
        let consul = consul_with([
            ("database_url", "postgres://from-consul/db"),
            ("jwt.secret", "secret-from-consul"),
        ]);
        let cfg = AppConfig::from_consul_and_env(&consul);
        clear_app_env();
        assert!(!cfg.app_name.is_empty());
        assert_eq!(cfg.app_env, "development");
        assert_eq!(cfg.app_port, 8080);
        assert_eq!(cfg.app_host, "0.0.0.0");
<%_ if (!devDatabaseTypeMongodb) { _%>
        assert_eq!(cfg.database_url, "postgres://from-consul/db");
<%_ } _%>
<%_ if (authenticationTypeJwt) { _%>

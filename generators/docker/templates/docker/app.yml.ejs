<%_
// Default database type flags if not set (for standalone docker generation)
const isPostgresql = typeof devDatabaseTypePostgresql !== 'undefined' ? devDatabaseTypePostgresql : false;
const isMysql = typeof devDatabaseTypeMysql !== 'undefined' ? devDatabaseTypeMysql : false;
const isMongodb = typeof devDatabaseTypeMongodb !== 'undefined' ? devDatabaseTypeMongodb : false;
const isSqlite = typeof devDatabaseTypeSqlite !== 'undefined' ? devDatabaseTypeSqlite : (!isPostgresql && !isMysql && !isMongodb);
const hasConsul = typeof serviceDiscoveryConsul !== 'undefined' ? serviceDiscoveryConsul : false;
const isOauth2 = typeof authenticationTypeOauth2 !== 'undefined' ? authenticationTypeOauth2 : false;
_%>
# This configuration is intended for development purpose, it's **your** responsibility to harden it for production
name: <%= baseName.toLowerCase() %>
services:
  app:
    image: <%= baseName.toLowerCase() %>
    build:
      # Track 1-a.4 fix (2026-06-07): docker compose resolves `context:`
      # relative to the COMPOSE FILE's directory, not the user's pwd.
      # This file lives at docker/app.yml, so `context: .` resolved to
      # docker/ — but the blueprint emits Dockerfile at the project
      # root (one level up). Result: `docker compose -f docker/app.yml
      # up --build` failed for every downstream user with:
      #     open Dockerfile: no such file or directory
      # `context: ..` points back at the project root.
      context: ..
      dockerfile: Dockerfile
    environment:
      - RUST_LOG=info
      # Track 1-a.4 fix (2026-06-07): override the Dockerfile's
      # `ENV APP_ENV=production` for the development compose. Production
      # mode refuses to start without CORS_ALLOWED_ORIGINS set, and this
      # file's own header declares "intended for development purpose".
      # Operators deploying to real environments override APP_ENV via
      # their orchestrator's env config (Kubernetes Deployment, ECS
      # task definition, etc.).
      - APP_ENV=development
<%_ if (isMongodb) { _%>
      # Track 1-a.4.3 fix (2026-06-08): include `?directConnection=true`.
      # Upstream's mongodb.yml initiates rs0 with `host: 'localhost:27017'`
      # — that works for mongo's own healthcheck but breaks any other
      # container's client. The client follows the replSet topology and
      # tries to connect to literal 'localhost:27017', resolving to the
      # client container itself (no mongo there → connection refused).
      # `directConnection=true` tells the driver to use the URI's host
      # directly and ignore replSet-advertised addresses.
      - MONGODB_URI=mongodb://mongodb:27017/?directConnection=true
      - MONGODB_DATABASE=<%= baseName.toLowerCase() %>
<%_ } else if (isPostgresql) { _%>
      # Track 1-a.4.1 fix: connect to upstream's `postgresql` service
      # (POSTGRES_USER=<baseName>, trust auth, DB defaults to user name).
      # Replaces the previous `db:5432` host which referenced a duplicate
      # postgres service that our template declared in parallel with
      # upstream's — both bound host port 5432 and conflicted.
      - DATABASE_URL=postgres://<%= baseName %>@postgresql:5432/<%= baseName %>
<%_ } else if (isMysql) { _%>
      # Track 1-a.4.1 fix: connect to upstream's `mysql` service
      # (MYSQL_ROOT_PASSWORD=root, MYSQL_DATABASE=<baseName lowercase>).
      - DATABASE_URL=mysql://root:root@mysql:3306/<%= baseName.toLowerCase() %>
<%_ } else { _%>
      # Track 1-a.4 fix (2026-06-07): use the Dockerfile-prepared
      # /app/target/db directory (owned by uid 1001 per the Dockerfile
      # USER directive). The prior relative path `./data/...` resolved
      # to /app/data inside the container, but the bind mount
      # `./data:/app/data` made docker create that dir as root on the
      # host — uid 1001 inside the container then got "unable to open
      # database file" trying to write to it.
      - DATABASE_URL=sqlite:///app/target/db/<%= baseName.toLowerCase() %>.db
<%_ } _%>
      - APP_HOST=0.0.0.0
      - APP_PORT=8080
<%_ if (authenticationTypeJwt) { _%>
      # Forwarded from .env so the entrypoint sees the same CSPRNG hex the
      # generator scaffolded. Empty → entrypoint generates a per-container hex.
      - JWT_SECRET=${JWT_SECRET:-}
<%_ } _%>
<%_ if (isOauth2) { _%>
      # Bug #18 fix (1-a.5.3): split OIDC URLs for docker compose.
      # OIDC_ISSUER_URI is the browser-facing URL (also the `iss` claim
      # KC_HOSTNAME pins Keycloak to emit); OIDC_INTERNAL_URI is the
      # docker-network URL the app calls directly for token exchange,
      # JWKS fetch, userinfo, end-session. Without the split, the app
      # tries to reach Keycloak at http://localhost:9080 from inside the
      # container, which is the app itself → "Connection refused" on
      # token exchange and the cypress OAuth2 flow fails.
      - OIDC_ISSUER_URI=http://localhost:9080/realms/jhipster
      - OIDC_INTERNAL_URI=http://keycloak:9080/realms/jhipster
      - OIDC_CLIENT_ID=web_app
      - OIDC_CLIENT_SECRET=web_app
<%_ } _%>
<%_ if (hasConsul) { _%>
      # Consul service discovery configuration
      - CONSUL_HOST=consul
      - CONSUL_PORT=8500
      - CONSUL_SERVICE_NAME=<%= baseName.toLowerCase() %>
      - CONSUL_REGISTER_SERVICE=true
      - CONSUL_REGISTER_HOST=app
      - CONSUL_HEALTH_CHECK_INTERVAL=10
<%_ } _%>
    ports:
      - 127.0.0.1:8080:8080
<%_ if (isSqlite) { _%>
    # Track 1-a.4 fix (2026-06-07): use a named volume for persistence
    # instead of `./data:/app/data` bind mount. Bind mounts to a
    # nonexistent host dir get created as root, making uid 1001 inside
    # the container unable to write. Named volumes are managed by
    # docker and inherit the container's user permissions correctly.
    volumes:
      - sqlite-data:/app/target/db
<%_ } _%>
<%_ if (isPostgresql || isMysql || isMongodb || hasConsul) { _%>
    # Track 1-a.4.1 fix: depend on upstream's service names. Previously
    # we waited on our own `db:` service AND upstream's `postgresql:` /
    # `mysql:` — the duplicate `db:` no longer exists.
    depends_on:
<%_ if (isPostgresql) { _%>
      postgresql:
        condition: service_healthy
<%_ } else if (isMysql) { _%>
      mysql:
        condition: service_healthy
<%_ } else if (isMongodb) { _%>
      mongodb:
        condition: service_healthy
<%_ } _%>
<%_ if (hasConsul) { _%>
      consul:
        condition: service_healthy
<%_ } _%>
<%_ } _%>
    healthcheck:
      test: ['CMD', 'curl', '-f', 'http://localhost:8080/api/health']
      interval: 5s
      timeout: 5s
      retries: 40
<%_ if (hasConsul) { _%>

  consul:
    image: hashicorp/consul:1.15
    ports:
      - 127.0.0.1:8500:8500  # HTTP API & UI
    command: consul agent -dev -ui -client 0.0.0.0 -log-level=INFO
    healthcheck:
      test: ['CMD', 'consul', 'members']
      interval: 5s
      timeout: 5s
      retries: 10
<%_ } _%>
# Track 1-a.4.1 (2026-06-07): postgres/mysql/mongo DB services are
# provided by upstream JHipster's docker generator (via extends: in
# this file). Previously we declared our own duplicates which conflicted
# on host ports and had different credentials. The `extends:` blocks
# upstream injects after our template renders bring in postgresql.yml /
# mysql.yml / mongodb.yml from the same docker/ directory; those files
# carry the actual service config (image, ports, healthcheck).
#
# Track 1-a.4.2 fix (2026-06-07): docker compose's `extends:` mechanism
# does NOT inherit top-level volume declarations from the extended file.
# Upstream's mysql.yml and mongodb.yml reference `mysql_data:` /
# `mongodb_data:` volumes inside their service block, but since OUR
# app.yml is the compose file being run, the volume names must be
# declared HERE. Without these, docker compose refuses to start with:
#     service "mysql" refers to undefined volume mysql_data: invalid compose project
# Upstream's postgresql.yml has its volume mount commented out, so no
# postgres volume is needed.
<%_ if (isSqlite || isMysql || isMongodb) { _%>
volumes:
<%_ if (isSqlite) { _%>
  # Track 1-a.4 fix (2026-06-07): named volume for the sqlite DB file
  # at /app/target/db/<baseName>.db. Bind mounts to non-existent host
  # dirs get created as root, preventing the container's uid 1001 user
  # from writing. Named volumes inherit the container's user perms.
  sqlite-data:
<%_ } else if (isMysql) { _%>
  mysql_data:
<%_ } else if (isMongodb) { _%>
  mongodb_data:
<%_ } _%>
<%_ } _%>
